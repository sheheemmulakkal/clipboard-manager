#!/bin/bash
set -e

# Kill running instances.
# Anchor to the start of the cmdline so we never match "apt remove clipboard-manager".
# The pattern covers both launch forms:
#   clipboard-manager          (launched by name via PATH — most common)
#   /usr/bin/clipboard-manager (launched with full path)
# Send SIGTERM first, wait briefly, then SIGKILL if still alive.
if pkill -TERM -f '^(/usr/bin/)?clipboard-manager( |$)' 2>/dev/null; then
    sleep 0.5
    pkill -KILL -f '^(/usr/bin/)?clipboard-manager( |$)' 2>/dev/null || true
fi

echo ""
echo "  Clipboard Manager has been removed."
echo ""

exit 0

#!/bin/bash
set -e

# Kill running instances.
# Match the full binary path so we don't accidentally kill the package manager
# (pkill -f "clipboard-manager" would also match "apt remove clipboard-manager").
# The installed binary is always /usr/bin/clipboard-manager.
# Send SIGTERM first, wait briefly, then SIGKILL if still alive.
if pkill -f '/usr/bin/clipboard-manager' 2>/dev/null; then
    sleep 0.5
    pkill -f -KILL '/usr/bin/clipboard-manager' 2>/dev/null || true
fi

echo ""
echo "  Clipboard Manager has been removed."
echo "  Your clipboard history and config files are kept at:"
echo "    ~/.config/clipboard-manager/"
echo "  Delete that folder manually if you want a clean uninstall."
echo ""

exit 0

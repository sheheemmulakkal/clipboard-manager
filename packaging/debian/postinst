#!/bin/bash
set -e

echo ""
echo "  ✓ Clipboard Manager installed successfully!"
echo ""
echo "  ► How to start now (no reboot needed):"
echo "    Run:  clipboard-manager &"
echo "    Or:   Log out and back in — it will start automatically."
echo ""
echo "  ► How to use:"
echo "    Copy any text as normal."
echo "    Press  Super + V  to see your clipboard history."
echo "    Click any item to paste it where your cursor is."
echo ""
echo "  ► Config file (optional):"
echo "    ~/.config/clipboard-manager/config.toml"
echo ""
echo "  ► To uninstall:"
echo "    sudo apt remove clipboard-manager"
echo ""

# If running interactively (not in CI), try to start it right now
# without requiring a reboot
if [ -n "$DISPLAY" ] || [ -n "$WAYLAND_DISPLAY" ]; then
  # Start for all logged-in users (best effort, don't fail if it errors)
  if command -v clipboard-manager >/dev/null 2>&1; then
    # Run as the current sudo user if SUDO_USER is set
    if [ -n "$SUDO_USER" ]; then
      su - "$SUDO_USER" -c "GDK_BACKEND=x11 nohup clipboard-manager >/dev/null 2>&1 &" || true
    fi
  fi
fi

exit 0

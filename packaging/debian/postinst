#!/bin/bash
set -e

echo ""
echo "  ✓ Clipboard Manager installed successfully!"
echo ""
echo "  ► How to use:"
echo "    Copy any text as normal."
echo "    Press  Ctrl + Alt + C  to open clipboard history."
echo ""
echo "  ► Config file:"
echo "    ~/.config/clipboard-manager/config.toml"
echo ""
echo "  ► To uninstall:"
echo "    sudo apt remove clipboard-manager"
echo ""

# Try to start the app immediately so the user doesn't need to log out.
# Runs only when invoked interactively (SUDO_USER is set and a display exists).
#
# Problem: postinst runs inside dpkg as root. "su - USER" opens a login shell
# which resets the environment — $DISPLAY is lost and GTK silently fails.
# Fix: read DISPLAY from the user's running processes via /proc, then pass it
# explicitly to runuser (which inherits the env without a login-shell reset).
if [ -n "$SUDO_USER" ] && command -v clipboard-manager >/dev/null 2>&1; then
  SUDO_UID=$(id -u "$SUDO_USER" 2>/dev/null) || true
  if [ -n "$SUDO_UID" ]; then
    USER_DISPLAY=$(
      pgrep -u "$SUDO_UID" 2>/dev/null \
        | xargs -I{} cat /proc/{}/environ 2>/dev/null \
        | tr '\0' '\n' \
        | grep -m1 '^DISPLAY=' \
        | cut -d= -f2-
    ) || true
    if [ -n "$USER_DISPLAY" ]; then
      DISPLAY="$USER_DISPLAY" runuser -u "$SUDO_USER" -- \
        bash -c 'nohup clipboard-manager >/dev/null 2>&1 &' || true
    fi
  fi
fi

exit 0
